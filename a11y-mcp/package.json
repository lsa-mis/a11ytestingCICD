{
  "name": "a11y-alfa-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server exposing Siteimprove Alfa WCAG accessibility audits as agent-callable tools — the same engine as this repo's CI gate.",
  "bin": {
    "a11y-alfa-mcp": "dist/server.js"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "smoke": "node smoke.mjs",
    "demo": "node demo.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@siteimprove/alfa-playwright": "^0.84.1",
    "@siteimprove/alfa-test-utils": "^0.84.1",
    "playwright": "^1.61.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.6.3"
  }
}
